{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3UploadPermissions",
            "Effect": "Allow",
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::serverless-event-driven-notification-uploaded-files/*"
        },
        {
            "Sid": "DynamoDBLoggingPermissions",
            "Effect": "Allow",
            "Action": "dynamodb:PutItem",
            "Resource": "arn:aws:dynamodb:us-east-1:183631313081:table/ServelessEventDrivenNotificationTable"
        },
        {
            "Sid": "SNSNotificationPermissions",
            "Effect": "Allow",
            "Action": "sns:Publish",
            "Resource": "arn:aws:sns:us-east-1:183631313081:ServerlessUploadNotificationTopic"
        },
        {
            "Sid": "CloudWatchLogging",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": "arn:aws:logs:*:*:*"
        }
    ]
}